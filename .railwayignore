# Top-level Railway ignore
# Do not hide backend source files from Nixpacks build

# Ignore flutter/dart workspace items to prevent Dart detection
frontend/
pubspec.yaml
pubspec.lock
*.dart

# Keep VCS and local noise out of builds
.git/
*.tmp
*.temp
*.log

# Allow backend code and configs
!backend/**
!package.json
!package-lock.json
!railway.json
!railway.toml
