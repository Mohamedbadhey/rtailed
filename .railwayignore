# Top-level Railway ignore
# Do not hide backend source files from Nixpacks build

# Ignore flutter/dart workspace items to prevent Dart detection
frontend/
pubspec.yaml
pubspec.lock
*.dart

# Keep VCS and local noise out of builds
.git/
*.tmp
*.temp
*.log

# Allow backend code and configs
# But explicitly ignore Dockerfiles to avoid Docker builder auto-detection
Dockerfile
!backend/**
!package.json
!package-lock.json
!railway.json
!railway.toml

# Re-ignore backend Dockerfile even after unignoring backend/**
backend/Dockerfile
