# Keep backend lean; do NOT exclude source files used by Node

# Ignore frontend artifacts (this service is backend-only)
web-app/

# Ignore local scripts/logs/backups
*.bat
*.log
*.tmp
*.temp

# Ignore large uploaded assets; runtime volume or object storage should hold these
uploads/*
!uploads/.gitkeep

# Ignore node_modules (Railway will install)
node_modules/

# Allow all .js/.json/.sql sources needed by the app
!**/*.js
!**/*.json
!**/*.sql
!package.json
!package-lock.json
!README.md
