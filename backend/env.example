# Database Configuration
# Railway automatically injects MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT when you link a MySQL service.
# Fallbacks (used locally or if not bound):
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=retail_management
DB_PORT=3306

# Optional connection tuning (override only if needed)
# Prefer IPv4 over IPv6 DNS answers (node >= 18)
DNS_RESULT_ORDER=ipv4first
# Connection pool size and timeouts
MYSQL_CONNECTION_LIMIT=10
MYSQL_CONNECT_TIMEOUT=10000
# TLS to connect to providers that require SSL (set to true on Railway if needed)
MYSQL_SSL=false
# If enabling SSL and Railway provides a CA, set this to true; otherwise false to allow self-signed/unknown CA
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# CORS Configuration
CORS_ORIGIN=*

# Admin Code (for superadmin registration)
ADMIN_CODE=SUPERADMIN2024 