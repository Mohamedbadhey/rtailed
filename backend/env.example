# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=retail_management
# Railway/MySQL service variables (if provided by your host)
MYSQLHOST=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQLPORT=3306
MYSQL_SSL=false
MYSQL_CONNECT_TIMEOUT=4000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# CORS Configuration
CORS_ORIGIN=*

# Admin Code (for superadmin registration)
ADMIN_CODE=SUPERADMIN2024 